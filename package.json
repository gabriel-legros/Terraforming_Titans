{
  "name": "terraforming-titans",
  "version": "1.0.0",
  "private": true,
  "productName": "Terraforming Titans",
  "main": "electron/main.cjs",
  "scripts": {
    "audit:localization": "node scripts/audit-localization.js",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir",
    "electron:dev": "electron .",
    "test": "jest"
  },
  "build": {
    "appId": "com.terraformingtitans.game",
    "productName": "Terraforming Titans",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "vendor/**/*",
      "LICENSES/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "LICENSES",
        "to": "LICENSES"
      }
    ],
    "win": {
      "target": "dir",
      "icon": "assets/images/cover_small.png"
    },
    "mac": {
      "target": "dir",
      "icon": "assets/images/cover_small.png"
    },
    "linux": {
      "target": "dir",
      "icon": "assets/images/cover_small.png",
      "category": "Game"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "babel-jest": "^30.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "jsdom": "^27.0.1",
    "playwright": "^1.61.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/__tests__/late-game-ui-memory-leaks.test.js$"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!jsdom|abab|cssom|cssstyle|data-urls|decimal.js|domexception|html-encoding-sniffer|is-potential-custom-element-name|nwsapi|parse5|saxes|symbol-tree|tough-cookie|w3c-xmlserializer|webidl-conversions|whatwg-url|xml-name-validator)"
    ]
  },
  "dependencies": {
    "steamworks.js": "^0.4.0"
  }
}
